# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# JWT
JWT_SECRET=change_this_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=change_this_encryption_key_minimum_32_characters

# Redis
REDIS_URL=redis://:password@redis-host:6379

# Frontend URL (for CORS, email links)
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGIN=https://your-frontend-domain.com

# Sentry (optional)
SENTRY_DSN=

# OTP provider
OTP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# AmoCRM integration
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://api.yourdomain.com/api/integrations/amocrm/callback
AMOCRM_BASE_URL=https://www.amocrm.ru
AMOCRM_WEBHOOK_SECRET=

# Telegram integration
TELEGRAM_BOT_TOKEN=

# UTeL integration
UTEL_API_URL=https://api.utel.uz
UTEL_API_TOKEN=
UTEL_WEBHOOK_SECRET=

# Notifications / exports
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
SENDGRID_FROM_NAME=Dashboarduz

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Runtime
NODE_ENV=production
PORT=3001
SKIP_ENV_VALIDATION=false
