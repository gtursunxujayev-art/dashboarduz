{
    "name": "@dashboarduz/api",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": ">=20 <25"
    },
    "description": "Dashboarduz API - Multi-Tenant CRM Integrator Backend",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "dev:worker": "tsx watch src/workers/worker.ts",
        "build": "npm run build:packages && tsc",
        "build:packages": "npm run build --workspace @dashboarduz/db && npm run build --workspace @dashboarduz/shared",
        "start": "node dist/index.js",
        "start:worker": "node dist/workers/worker.js",
        "type-check": "npm run build:packages && tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "db:generate": "npm run generate --workspace @dashboarduz/db",
        "db:migrate": "npm run migrate --workspace @dashboarduz/db",
        "db:migrate:deploy": "npm run migrate:deploy --workspace @dashboarduz/db",
        "db:studio": "npm run studio --workspace @dashboarduz/db",
        "db:push": "npm run db:push --workspace @dashboarduz/db",
        "test": "jest --passWithNoTests",
        "docker:build": "docker build -t dashboarduz-api .",
        "docker:run": "docker run -p 3001:3001 dashboarduz-api",
        "postinstall": "echo 'Prisma generation handled in Dockerfile or run manually with npm run db:generate'",
        "migrate:deploy": "npx prisma migrate deploy --schema=../../packages/db/prisma/schema.prisma"
    },
    "dependencies": {
        "@dashboarduz/db": "file:../../packages/db",
        "@dashboarduz/shared": "file:../../packages/shared",
        "@sentry/node": "^7.91.0",
        "@trpc/server": "^10.45.0",
        "bullmq": "^5.9.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "pino": "^8.19.0",
        "pino-pretty": "^10.3.1",
        "superjson": "^2.2.6",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "eslint": "^8.56.0",
        "eslint-plugin-import": "^2.29.1",
        "ts-jest": "^29.4.9",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}
